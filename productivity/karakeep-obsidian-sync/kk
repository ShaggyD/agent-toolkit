#!/usr/bin/env python3
"""
kk — Karakeep CLI. Full CRUD for self-hosted bookmarking, with optional Obsidian vault sync.

Usage:
  kk login <url> <api_key>                    Configure connection
  kk list [--limit N]                         List recent bookmarks
  kk get <id>                                  Get bookmark details as JSON
  kk add <url>                                 Save a link bookmark
  kk text <content>                            Save a text bookmark
  kk note <id> [text]                         View or update note on a bookmark
  kk edit <id> --title= --note=               Update bookmark fields
  kk tag <id> <tag>...                         Attach tags to a bookmark
  kk untag <id> <tag>...                       Detach tags from a bookmark
  kk delete <id>                               Delete a bookmark
  kk sync                                      Pull new bookmarks → Obsidian vault (if configured)
  kk push                                      Push vault note changes → Karakeep (if configured)
  kk config [--set key=val]                   Show or update configuration
  kk logout                                    Wipe saved config and state
"""

import os, sys, json, re, argparse, urllib.request, urllib.error
from datetime import datetime, timezone
from pathlib import Path

# ── Config ────────────────────────────────────────────────────────────────
CONFIG_DIR = Path.home() / ".config" / "kk"
CONFIG_FILE = CONFIG_DIR / "config.json"
STATE_FILE = CONFIG_DIR / "state.json"

DESCRIPTION = """
Karakeep CLI — full CRUD for your self-hosted bookmarking instance.
Obsidian vault sync is optional; all CRUD commands work without it.
"""


def load_config():
    if not CONFIG_FILE.exists():
        return {}
    with open(CONFIG_FILE) as f:
        return json.load(f)


def save_config(cfg):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(cfg, f, indent=2)


def load_state():
    if not STATE_FILE.exists():
        return {"last_sync_cursor": None, "last_sync_at": None, "last_push_at": None}
    with open(STATE_FILE) as f:
        return json.load(f)


def save_state(state):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(STATE_FILE, "w") as f:
        json.dump(state, f, indent=2)


def get_vault_dir():
    """Return the vault bookmarks directory, or None if not configured."""
    cfg = load_config()
    raw = cfg.get("vault_path")
    if not raw:
        return None
    return Path(raw).expanduser().resolve()


def get_daily_dir():
    """Return the daily notes directory, inferred or explicit."""
    cfg = load_config()
    raw = cfg.get("daily_path")
    if raw:
        return Path(raw).expanduser().resolve()

    # Infer from vault_path: if bookmarks are at .../003_Resources/Bookmarks,
    # assume daily notes at .../002_Journal/daily/
    vp = cfg.get("vault_path")
    if not vp:
        return None
    vp = Path(vp).expanduser().resolve()
    if vp.name == "Bookmarks" and vp.parent.name == "003_Resources":
        inferred = vp.parent.parent / "002_Journal" / "daily"
        if inferred.exists():
            return inferred
    return None


# ── API ───────────────────────────────────────────────────────────────────

class KarakeepAPI:
    def __init__(self):
        cfg = load_config()
        self.base_url = cfg.get("url", "").rstrip("/")
        self.api_key = cfg.get("api_key", "")
        if not self.base_url or not self.api_key:
            die("Not configured. Run: kk login <url> <api_key>")

    def _headers(self):
        return {
            "Authorization": f"Bearer {self.api_key}",
            "Content-Type": "application/json",
            "User-Agent": "kk-cli/0.4",
        }

    def _req(self, method, path, data=None, params=None):
        url = f"{self.base_url}/api/v1{path}"
        if params:
            qs = "&".join(f"{k}={urllib.request.quote(str(v))}" for k, v in params.items())
            url = f"{url}?{qs}"
        body = json.dumps(data).encode() if data else None
        req = urllib.request.Request(url, data=body, method=method, headers=self._headers())
        try:
            with urllib.request.urlopen(req) as resp:
                raw = resp.read()
                if raw:
                    return json.loads(raw.decode())
                return {}
        except urllib.error.HTTPError as e:
            body = e.read().decode()[:300]
            die(f"HTTP {e.code} on {method} {path}: {body}")

    def list_bookmarks(self, limit=50, cursor=None):
        params = {"limit": limit}
        if cursor:
            params["cursor"] = cursor
        return self._req("GET", "/bookmarks", params=params)

    def get_bookmark(self, bm_id):
        return self._req("GET", f"/bookmarks/{bm_id}")

    def create_bookmark(self, data):
        return self._req("POST", "/bookmarks", data=data)

    def update_bookmark(self, bm_id, data):
        return self._req("PATCH", f"/bookmarks/{bm_id}", data=data)

    def delete_bookmark(self, bm_id):
        return self._req("DELETE", f"/bookmarks/{bm_id}")

    def attach_tags(self, bm_id, tag_names):
        return self._req("POST", f"/bookmarks/{bm_id}/tags",
                         data={"tags": [{"tagName": t} for t in tag_names]})

    def detach_tags(self, bm_id, tag_names):
        return self._req("DELETE", f"/bookmarks/{bm_id}/tags",
                         data={"tags": [{"tagName": t} for t in tag_names]})


# ── Helpers ───────────────────────────────────────────────────────────────

def die(msg):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def prompt(msg, default=None):
    suffix = f" [{default}]" if default else ""
    try:
        return input(f"{msg}{suffix}: ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return default or ""


def fmt_date(iso_str):
    try:
        dt = datetime.fromisoformat(iso_str.replace("Z", "+00:00"))
        return dt.strftime("%Y-%m-%d %H:%M")
    except:
        return iso_str


def slugify(text):
    s = text.lower().strip()
    s = re.sub(r'[^\w\s-]', '', s)
    s = re.sub(r'[-\s]+', '-', s)
    return s[:80]


def bm_display(bm):
    bm_id = bm["id"]
    created = fmt_date(bm.get("createdAt", ""))
    ctype = bm.get("content", {}).get("type", "?")
    title = bm.get("content", {}).get("title") or bm.get("content", {}).get("text", "") or "(no title)"
    tags = ", ".join(t["name"] for t in bm.get("tags", []))
    url = bm.get("content", {}).get("url", "")
    fav = "★" if bm.get("favourited") else " "
    arch = "📦" if bm.get("archived") else "  "
    note = bm.get("note", "") or ""
    line = f"{fav}{arch} {bm_id[:12]}... {created} [{ctype}] {title[:72]}"
    if url:
        line += f"\n       url: {url[:100]}"
    if note:
        line += f"\n       note: {note[:60]}"
    if tags:
        line += f"\n       tags: {tags[:80]}"
    return line


def parse_frontmatter(text):
    m = re.match(r'^---\s*\n(.*?)\n---\s*\n', text, re.DOTALL)
    if not m:
        return {}
    fm = {}
    for line in m.group(1).strip().split('\n'):
        if ':' in line:
            key, _, val = line.partition(':')
            key = key.strip()
            val = val.strip()
            if val.startswith('[') and val.endswith(']'):
                val = [v.strip() for v in val[1:-1].split(',') if v.strip()]
            fm[key] = val
    return fm


def bm_to_note_content(bm):
    """Convert a Karakeep bookmark into an Obsidian note. No personal tags or conventions."""
    ctype = bm.get("content", {}).get("type", "link")
    content = bm.get("content", {})
    bm_id = bm["id"]
    created = bm.get("createdAt", "")
    title = content.get("title") or content.get("text", "") or "Untitled"
    summary = bm.get("summary") or ""
    note_text = bm.get("note") or ""
    tags = [t["name"] for t in bm.get("tags", [])]
    url = content.get("url", "")
    author = content.get("author", "")
    publisher = content.get("publisher", "")

    frontmatter = {
        "created": fmt_date(created),
        "source": "karakeep",
        "karakeep_id": bm_id,
        "source_url": url or "",
        "author": author or "",
        "publisher": publisher or "",
        "tags": tags,
    }

    lines = ["---"]
    for k, v in frontmatter.items():
        if isinstance(v, list):
            lines.append(f'{k}: [{", ".join(v)}]' if v else f"{k}: []")
        elif v:
            lines.append(f"{k}: {v}")
        else:
            lines.append(f"{k}:")
    lines.append("---")
    lines.append("")
    lines.append(f"# {title}")
    lines.append("")

    if summary:
        lines.append(summary)
        lines.append("")

    if url and ctype == "link":
        lines.append(f"**URL:** [{url}]({url})")
        lines.append("")

    if note_text:
        lines.append("---")
        lines.append("## Notes")
        lines.append("")
        lines.append(note_text)
        lines.append("")

    lines.append("---")
    lines.append("")
    lines.append("See also: [[_Index|Bookmarks]]")

    return "\n".join(lines)


def note_filename(bm):
    content = bm.get("content", {})
    title = content.get("title") or content.get("text", "") or "untitled"
    created = bm.get("createdAt", "")
    try:
        dt = datetime.fromisoformat(created.replace("Z", "+00:00"))
        date_prefix = dt.strftime("%Y-%m-%d")
    except:
        date_prefix = "unknown"
    slug = slugify(title)
    return f"{date_prefix}-{slug}.md"


def note_filepath_from_bm(bm):
    vault = get_vault_dir()
    if not vault:
        return None
    return vault / note_filename(bm)


def ensure_index_note(vault_dir):
    """Create _Index.md if it doesn't exist."""
    idx = vault_dir / "_Index.md"
    if idx.exists():
        return
    folder_name = vault_dir.name
    idx.write_text(f"""---
created: {datetime.now().strftime('%Y-%m-%d')}
source: karakeep
tags: [bookmarks, index]
---

# Bookmarks Index

Bookmarks synced from Karakeep.

---

## Recently Added

```dataview
TABLE summary as "Summary", tags as "Tags", created as "Saved"
FROM "{folder_name}"
WHERE source = "karakeep"
SORT created desc
LIMIT 20
```

## By Tag

```dataview
TABLE rows.file.link as "Bookmarks"
FROM "{folder_name}"
WHERE source = "karakeep" AND tags
FLATTEN tags as tag
GROUP BY tag
SORT tag asc
```
""")


def append_daily_note(count, vault_dir):
    """Append sync summary to today's daily note if daily_dir resolves."""
    daily_dir = get_daily_dir()
    if not daily_dir:
        return  # silently skip — daily notes not configured
    today = datetime.now().strftime("%Y-%m-%d")
    daily_path = daily_dir / f"{today}.md"
    try:
        daily_dir.mkdir(parents=True, exist_ok=True)
        line = f"- Synced [[{vault_dir.name}/_Index|{count} bookmark{'s' if count != 1 else ''}]] from Karakeep"
        if daily_path.exists():
            text = daily_path.read_text()
            if line in text:
                return
            daily_path.write_text(text.rstrip() + f"\n{line}\n")
        else:
            daily_path.write_text(f"---\ncreated_at: {today}\ndate: {today}\ntags: daily\n---\n\n{line}\n")
    except Exception as e:
        print(f"  (daily note skipped: {e})")


# ── Commands ──────────────────────────────────────────────────────────────

def cmd_login(args):
    cfg = load_config()
    cfg["url"] = args.url
    cfg["api_key"] = args.api_key
    save_config(cfg)

    try:
        KarakeepAPI().list_bookmarks(limit=1)
        print(f"✓ Connected to {args.url}")
    except Exception as e:
        die(f"Connection failed: {e}")

    # Optional vault setup
    print()
    ans = prompt("Configure Obsidian vault sync? (optional)", default="y/N").lower()
    if ans in ("y", "yes"):
        default_path = cfg.get("vault_path", "")
        p = prompt("  Path to bookmarks directory", default=default_path)
        if p:
            cfg["vault_path"] = str(Path(p).expanduser().resolve())
            save_config(cfg)
            print(f"  ✓ Bookmarks directory set to {cfg['vault_path']}")

            dp = prompt("  Path to daily notes (optional, for sync cross-refs)", default="(skip)")
            if dp and dp != "(skip)":
                cfg["daily_path"] = str(Path(dp).expanduser().resolve())
                save_config(cfg)
                print(f"  ✓ Daily notes path set")

            ans2 = prompt("  Run initial sync now?", default="Y/n").lower()
            if ans2 in ("", "y", "yes"):
                print()
                cmd_sync(None)
    else:
        print("  (skip — can configure later with: kk config --set vault_path=/path/to/bookmarks)")


def cmd_logout(args):
    """Wipe config and state."""
    confirm = prompt("This will remove all saved configuration and sync state. Continue?", default="y/N")
    if confirm.lower() not in ("y", "yes"):
        print("Aborted.")
        return
    for fp in [CONFIG_FILE, STATE_FILE]:
        if fp.exists():
            fp.unlink()
            print(f"  removed {fp}")
    print("✓ Logged out")


def cmd_list(args):
    api = KarakeepAPI()
    all_bms = []
    cursor = None
    while len(all_bms) < args.limit:
        resp = api.list_bookmarks(limit=min(50, args.limit), cursor=cursor)
        all_bms.extend(resp.get("bookmarks", []))
        cursor = resp.get("nextCursor")
        if not cursor:
            break
    if not all_bms:
        print("No bookmarks found.")
        return
    for bm in all_bms[:args.limit]:
        print(bm_display(bm))
        print()


def cmd_get(args):
    api = KarakeepAPI()
    bm = api.get_bookmark(args.id)
    print(json.dumps(bm, indent=2))


def cmd_add(args):
    api = KarakeepAPI()
    bm = api.create_bookmark({"type": "link", "url": args.url})
    print(f"✓ Created bookmark {bm['id']}")
    print(bm_display(bm))


def cmd_text(args):
    api = KarakeepAPI()
    bm = api.create_bookmark({"type": "text", "text": args.content})
    print(f"✓ Created text bookmark {bm['id']}")
    print(bm_display(bm))


def cmd_note(args):
    api = KarakeepAPI()
    if args.text is not None:
        api.update_bookmark(args.id, {"note": args.text})
        print(f"✓ Note updated on {args.id[:12]}...")
    else:
        bm = api.get_bookmark(args.id)
        note = bm.get("note") or "(no note)"
        print(f"Note for {args.id[:12]}...:")
        print(note)


def cmd_edit(args):
    api = KarakeepAPI()
    data = {}
    if args.title is not None:
        data["title"] = args.title
    if args.note is not None:
        data["note"] = args.note
    if args.archived is not None:
        data["archived"] = args.archived
    if args.favourited is not None:
        data["favourited"] = args.favourited
    if not data:
        die("Nothing to update. Use --title, --note, --archived, --favourited")
    api.update_bookmark(args.id, data)
    print(f"✓ Updated {args.id[:12]}...")


def cmd_tag(args):
    api = KarakeepAPI()
    api.attach_tags(args.id, args.tags)
    print(f"✓ Tags attached to {args.id[:12]}...")


def cmd_untag(args):
    api = KarakeepAPI()
    api.detach_tags(args.id, args.tags)
    print(f"✓ Tags detached from {args.id[:12]}...")


def cmd_delete(args):
    api = KarakeepAPI()
    api.delete_bookmark(args.id)
    print(f"✓ Deleted {args.id[:12]}...")


def cmd_sync(args):
    """Pull new bookmarks from Karakeep → Obsidian vault (if configured)."""
    vault_dir = get_vault_dir()
    if not vault_dir:
        die("vault_path not configured. Set one up:\n  kk config --set vault_path=/path/to/bookmarks\n  kk sync")

    api = KarakeepAPI()
    state = load_state()
    vault_dir.mkdir(parents=True, exist_ok=True)
    ensure_index_note(vault_dir)

    last_cursor = state.get("last_sync_cursor")
    new_count = 0
    skipped_count = 0

    print(f"Syncing bookmarks to {vault_dir} ...")

    cursor = None
    done = False
    bookmarks = []
    while not done:
        resp = api.list_bookmarks(limit=50, cursor=cursor)
        page = resp.get("bookmarks", [])
        next_cursor = resp.get("nextCursor")

        if not page:
            break

        for bm in page:
            bm_id = bm["id"]
            if last_cursor and bm_id == last_cursor:
                done = True
                break

            fp = note_filepath_from_bm(bm)
            if fp and fp.exists():
                try:
                    if f"karakeep_id: {bm_id}" in fp.read_text():
                        skipped_count += 1
                        continue
                except:
                    pass

            content = bm_to_note_content(bm)
            if fp:
                fp.parent.mkdir(parents=True, exist_ok=True)
                fp.write_text(content)
                new_count += 1
                title = bm.get("content", {}).get("title") or bm.get("content", {}).get("text", "") or "untitled"
                print(f"  + {title[:60]}")

        if done or not next_cursor:
            break
        cursor = next_cursor
        bookmarks.extend(page)

    if bookmarks:
        state["last_sync_cursor"] = bookmarks[0]["id"]
        state["last_sync_at"] = datetime.now(timezone.utc).isoformat()
        save_state(state)

    print()
    if new_count:
        print(f"✓ {new_count} new bookmarks synced")
        append_daily_note(new_count, vault_dir)
    else:
        print("✓ No new bookmarks to sync")
    if skipped_count:
        print(f"  ({skipped_count} already existed, skipped)")


def cmd_push(args):
    """Push vault note changes back to Karakeep (if vault is configured)."""
    vault_dir = get_vault_dir()
    if not vault_dir:
        die("vault_path not configured. Set one up:\n  kk config --set vault_path=/path/to/bookmarks")

    if not vault_dir.exists():
        die(f"Directory not found: {vault_dir}\n  Run kk sync first.")

    api = KarakeepAPI()
    state = load_state()
    updated_count = 0
    error_count = 0

    print(f"Scanning {vault_dir} for notes to push to Karakeep...")

    for fp in sorted(vault_dir.glob("*.md"), key=lambda p: p.stat().st_mtime, reverse=True):
        if fp.name == "_Index.md":
            continue
        text = fp.read_text()
        fm = parse_frontmatter(text)
        bm_id = fm.get("karakeep_id")
        if not bm_id:
            continue

        note_match = re.search(r'^## Notes\s*\n(.*?)(?:\n---|\Z)', text, re.DOTALL | re.MULTILINE)
        vault_note = note_match.group(1).strip() if note_match else ""

        if not vault_note:
            continue

        try:
            bm = api.get_bookmark(bm_id)
            if vault_note == (bm.get("note") or ""):
                continue
            api.update_bookmark(bm_id, {"note": vault_note})
            print(f"  ↑ {fm.get('source_url', fm.get('created', '?'))[:70]}")
            updated_count += 1
        except SystemExit:
            error_count += 1
            print(f"  ✗ failed: {bm_id[:12]}...")
        except Exception as e:
            error_count += 1
            print(f"  ✗ {bm_id[:12]}...: {e}")

    state["last_push_at"] = datetime.now(timezone.utc).isoformat()
    save_state(state)

    print()
    if updated_count:
        print(f"✓ {updated_count} notes pushed to Karakeep")
    if error_count:
        print(f"  ({error_count} errors)")
    if not updated_count and not error_count:
        print("(no notes with changes to push)")


def cmd_config(args):
    cfg = load_config()

    if args.set:
        for pair in args.set:
            if "=" not in pair:
                print(f"warning: ignoring '{pair}' — use key=val format")
                continue
            key, _, val = pair.partition("=")
            cfg[key.strip()] = val.strip()
        save_config(cfg)
        changes = len(args.set)
        print(f"✓ Config updated ({changes} change{'s' if changes != 1 else ''})")
        return

    if not cfg:
        print("Not configured. Run: kk login <url> <api_key>")
        return

    safe = {k: v for k, v in cfg.items()}
    if "api_key" in safe:
        safe["api_key"] = safe["api_key"][:12] + "..." + safe["api_key"][-4:]
    print(json.dumps(safe, indent=2))

    state = load_state()
    if state.get("last_sync_at"):
        print(f"\nlast_sync_at: {state['last_sync_at']}")
    if state.get("last_push_at"):
        print(f"last_push_at: {state['last_push_at']}")

    vd = get_vault_dir()
    print(f"\nvault_dir: {vd or '(not configured — CRUD commands work without it)'}")
    dd = get_daily_dir()
    print(f"daily_dir: {dd or '(not configured)'}")


# ── Main ──────────────────────────────────────────────────────────────────

VERSION = "0.4.0"


def main():
    parser = argparse.ArgumentParser(
        prog="kk",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        description=DESCRIPTION,
        epilog=(
            "Examples:\n"
            "  kk login https://hoarder.example.com ak2_my_key\n"
            "  kk list --limit 5\n"
            "  kk add https://example.com/article\n"
            "  kk config --set vault_path=~/my-vault/Bookmarks\n"
            "  kk sync\n"
            "\nFull docs: https://github.com/ShaggyD/AGENT_SKILLS\n"
        ),
    )
    parser.add_argument("--version", action="version", version=f"kk {VERSION}")

    sub = parser.add_subparsers(dest="command", required=True)

    # login
    p = sub.add_parser("login", help="Connect to a Karakeep instance (vault sync is optional)")
    p.add_argument("url", help="Instance URL (e.g. https://hoarder.example.com)")
    p.add_argument("api_key", help="API key from Settings → API Keys")

    # logout
    sub.add_parser("logout", help="Wipe saved config and state")

    # list
    p = sub.add_parser("list", help="List recent bookmarks")
    p.add_argument("--limit", type=int, default=20, help="Max results (default: 20)")

    # get
    p = sub.add_parser("get", help="Get full bookmark details as JSON")
    p.add_argument("id", help="Bookmark ID")

    # add
    p = sub.add_parser("add", help="Save a URL bookmark")
    p.add_argument("url", help="URL to save")

    # text
    p = sub.add_parser("text", help="Save a plain text bookmark")
    p.add_argument("content", help="Text content")

    # note
    p = sub.add_parser("note", help="View or update a bookmark's note field")
    p.add_argument("id", help="Bookmark ID")
    p.add_argument("text", nargs="?", default=None,
                   help="Note text (omit to view, pass '' to clear)")

    # edit
    p = sub.add_parser("edit", help="Update bookmark fields")
    p.add_argument("id", help="Bookmark ID")
    p.add_argument("--title", help="New title")
    p.add_argument("--note", help="New note text")
    p.add_argument("--archived", type=lambda x: x.lower() == "true",
                   help="Set archived (true/false)")
    p.add_argument("--favourited", type=lambda x: x.lower() == "true",
                   help="Set favourited (true/false)")

    # tag
    p = sub.add_parser("tag", help="Attach tags to a bookmark")
    p.add_argument("id", help="Bookmark ID")
    p.add_argument("tags", nargs="+", help="Space-separated tag names")

    # untag
    p = sub.add_parser("untag", help="Detach tags from a bookmark")
    p.add_argument("id", help="Bookmark ID")
    p.add_argument("tags", nargs="+", help="Space-separated tag names")

    # delete
    p = sub.add_parser("delete", help="Delete a bookmark")
    p.add_argument("id", help="Bookmark ID")

    # sync
    p = sub.add_parser("sync", help="Pull new bookmarks into the Obsidian vault (requires vault_path)")
    # push
